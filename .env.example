# Email Configuration - Environment Variables
# Copy this file to .env and fill in your credentials

# Gmail SMTP Configuration (Recommended)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-character-app-password

# Default sender address
MAIL_DEFAULT_SENDER=noreply@carrental.com

# Optional: Flask secret key for sessions
# SECRET_KEY=your-secret-key-for-production

# Notes:
# 1. MAIL_PASSWORD should be your Gmail App Password (16 chars), not your account password
# 2. To generate Gmail App Password:
#    - Enable 2-Step Verification: https://myaccount.google.com
#    - Go to App passwords in Security settings
#    - Generate password for Mail on this device
# 3. Do NOT commit this file to version control - it contains sensitive data
# 4. Add .env to .gitignore
